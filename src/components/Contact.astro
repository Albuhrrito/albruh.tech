---
const socials = [
  { label: 'GitHub', handle: '@Albuhrrito', href: 'https://github.com/Albuhrrito' },
  { label: 'LinkedIn', handle: 'albert-youssef', href: 'https://www.linkedin.com/in/albert-youssef-5420341ba/' },
  { label: 'Twitter', handle: '@albruh_u', href: 'https://twitter.com/albruh_u' },
  { label: 'Instagram', handle: '@albruh.u', href: 'https://www.instagram.com/albruh.u/' },
];
---
<section id="contact" class="relative py-32 md:py-48">
  <div class="wave-divider absolute top-0 left-0 right-0 -translate-y-1/2" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,0 L0,0 Z" fill="rgba(255,125,59,0.05)">
        <animate attributeName="d" dur="11s" repeatCount="indefinite"
          values="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,0 L0,0 Z;
                  M0,40 C240,0 480,55 720,25 C960,0 1200,50 1440,20 L1440,0 L0,0 Z;
                  M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,0 L0,0 Z" />
      </path>
    </svg>
  </div>
  <div class="mx-auto px-6" style="max-width: min(92vw, 1280px);">
    <div class="font-mono text-xs uppercase tracking-[0.3em] text-accent mb-16 flex items-center gap-4">
      <span class="block h-px w-12 bg-accent"></span>
      <span>02 / Contact</span>
    </div>

    <h2 class="font-display text-fg leading-[0.95] tracking-[-0.03em] mb-12" style="font-size: clamp(3rem, 10vw, 9rem);">
      Let's build<br /><span class="italic text-accent wave-underline">something good.</span>
    </h2>

    <div class="grid md:grid-cols-12 gap-12 items-end">
      <div class="md:col-span-7">
        <p class="text-fg-muted text-lg leading-relaxed max-w-2xl mb-10">
          Open to freelance work, full-time roles, and weird side-project collaborations. The fastest path to a reply is email.
        </p>

        <a
          href="mailto:albertm.youssef@gmail.com"
          class="magnetic group inline-flex items-center gap-4 font-display text-fg hover:text-accent transition-colors"
          style="font-size: clamp(1.5rem, 4vw, 3rem);"
        >
          albertm.youssef@gmail.com
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-2">→</span>
        </a>
      </div>

      <div class="md:col-span-5">
        <div class="font-mono text-[10px] uppercase tracking-[0.3em] text-fg-dim mb-6">Elsewhere</div>
        <ul class="space-y-3">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center justify-between py-3 border-b border-fg/10 hover:border-accent transition-colors"
              >
                <span class="font-mono text-xs uppercase tracking-[0.2em] text-fg-muted group-hover:text-accent transition-colors">
                  {s.label}
                </span>
                <span class="font-mono text-sm text-fg group-hover:text-accent transition-colors flex items-center gap-2">
                  {s.handle}
                  <span aria-hidden="true" class="opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all">↗</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
