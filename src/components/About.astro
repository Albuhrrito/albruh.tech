---
import { Image } from 'astro:assets';
import maskedface from '~/assets/about/maskedface.png';
---
<section id="about" class="relative py-32 md:py-48">
  <div class="mx-auto px-6" style="max-width: min(92vw, 1280px);">
    <div class="font-mono text-xs uppercase tracking-[0.3em] text-accent mb-16 flex items-center gap-4">
      <span class="block h-px w-12 bg-accent"></span>
      <span>00 / About</span>
    </div>

    <div class="grid md:grid-cols-12 gap-12 md:gap-16 items-start">
      <div class="md:col-span-4">
        <div class="relative aspect-[4/5] overflow-hidden rounded-2xl bg-bg-elev">
          <Image
            src={maskedface}
            alt="Albert Youssef"
            widths={[320, 480, 640]}
            sizes="(min-width: 768px) 33vw, 80vw"
            class="h-full w-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
          />
          <div class="absolute inset-0 ring-1 ring-inset ring-fg/10 rounded-2xl pointer-events-none"></div>
        </div>
        <div class="mt-4 font-mono text-[10px] uppercase tracking-[0.25em] text-fg-muted">
          Hover to focus
        </div>
      </div>

      <div class="md:col-span-8">
        <h2 class="font-display text-fg leading-[1.0] tracking-[-0.02em] mb-10" style="font-size: clamp(2.5rem, 5vw, 4.5rem);">
          Software & AI engineer based in <span class="italic text-accent wave-underline">California</span>, focused on LLM-powered systems, multi-agent architectures, and full-stack engineering.
        </h2>

        <div class="grid sm:grid-cols-2 gap-x-12 gap-y-6 text-fg-muted leading-relaxed mb-12">
          <p>
            UC Irvine '25 B.S. Software Engineering grad. I build AI-driven platforms — multi-agent game generation in Godot, natural-language-to-Unreal-Engine simulation pipelines, and brain-inspired ML research at BIASLab. Looking for software engineering, AI engineering, and applied ML roles.
          </p>
          <p>
            I do my best work on a team — pairing on architecture, reviewing PRs, and shipping with people. Off-hours: mechanical keyboards, lifting, and framing the next street photo through the Photograbert lens.
          </p>
        </div>

        <div class="mb-12">
          <div class="font-mono text-[10px] uppercase tracking-[0.3em] text-fg-dim mb-4">Toolkit</div>
          <div class="flex flex-wrap gap-2">
            {[
              'Python', 'TypeScript', 'C++', 'C#',
              'PyTorch', 'Hugging Face', 'LangChain / LangGraph', 'LangSmith',
              'Anthropic Claude API', 'OpenAI API', 'MCP', 'RAG',
              'Vector DBs', 'FastAPI', 'Node', 'React',
              'Unreal Engine 5', 'Unity', 'Godot',
              'Docker', 'AWS', 'Linux', 'Git'
            ].map((tag) => (
              <span class="font-mono text-xs px-3 py-1.5 rounded-full border border-fg/15 text-fg-muted hover:border-accent hover:text-accent transition-colors">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <div class="flex flex-wrap gap-4">
          <a
            href="/AlbertYoussefResume.pdf"
            target="_blank"
            rel="noopener"
            class="magnetic group inline-flex items-center gap-3 px-6 py-3 bg-fg text-bg hover:bg-accent hover:text-bg transition-colors font-mono text-sm uppercase tracking-[0.15em] rounded-full"
          >
            Resume
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">↗</span>
          </a>
          <a
            href="#contact"
            class="magnetic group inline-flex items-center gap-3 px-6 py-3 border border-fg/20 hover:border-accent text-fg hover:text-accent transition-colors font-mono text-sm uppercase tracking-[0.15em] rounded-full"
          >
            Get in touch
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
